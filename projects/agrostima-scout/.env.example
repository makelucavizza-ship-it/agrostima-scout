# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID_UTENTE=chat_id_del_perito
TELEGRAM_CHAT_ID_ADMIN=chat_id_admin

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend (email attivazione — opzionale)
# RESEND_API_KEY=your_resend_key
# RESEND_FROM=noreply@agrostima.it

# Database
# Locale: DB_PATH=../../data/shared.db
# Railway (con Volume montato su /data): DB_PATH=/data/shared.db
DB_PATH=../../data/shared.db

# Progetto — usato come tag nel DB
PROGETTO=agrostima

# URL della landing page (usato nei messaggi del bot Telegram)
# Es. Railway: LANDING_URL=https://agrostima-scout.up.railway.app
LANDING_URL=http://localhost:8000

# Ambiente
ENVIRONMENT=development
